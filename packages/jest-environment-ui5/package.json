{
    "name": "@sap-ux/jest-environment-ui5",
    "version": "5.3.19",
    "description": "Jest matchers for files and folders",
    "repository": {
        "type": "git",
        "url": "https://github.com/SAP/open-ux-tools.git",
        "directory": "packages/jest-environment-ui5"
    },
    "license": "Apache-2.0",
    "private": false,
    "types": "index.d.ts",
    "main": "src/index.js",
    "scripts": {
        "clean": "rimraf --glob dist coverage *.tsbuildinfo",
        "format": "prettier --write '**/*.{js,json,ts,yaml,yml}' --ignore-path ../../.prettierignore",
        "lint": "eslint --ext .js",
        "lint:fix": "eslint --ext .js --fix",
        "test": "pnpm run test:unit && pnpm run test:latest",
        "test:unit": "cross-env NODE_OPTIONS='--experimental-vm-modules' npx jest --ci --maxWorkers=1",
        "test:latest": "cross-env TEST_LATEST=true npm run test:e2e",
        "test:e2e": "node test/e2e.mjs",
        "link": "pnpm link --global",
        "unlink": "pnpm unlink --global"
    },
    "files": [
        "src",
        "LICENSE"
    ],
    "dependencies": {
        "jest-environment-jsdom": "^29.7.0",
        "tsconfig-paths": "^3.15.0"
    },
    "peerDependencies": {
        "@ui5/project": "^3.9.0 || ^4.0.11"
    },
    "devDependencies": {
        "@ui5/cli": "4.0.46",
        "@ui5/project": "4.0.11",
        "@sap-ux/ui5-config": "workspace:*",
        "@sap-ux/ui5-info": "workspace:*",
        "cross-env": "^10.0.0"
    },
    "engines": {
        "node": ">=20.x"
    }
}
