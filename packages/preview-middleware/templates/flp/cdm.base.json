{
    "_version": "3.1.0",
    "catalogs": {
        "homeCatalog": {
            "identification": {
                "id": "homeCatalog",
                "title": "Homepage Apps"
            },
            "payload": {
                "viz": []
            }
        }
    },
    "site": {
        "payload": {
            "groupsOrder": []
        }
    },
    "groups": {},
    "visualizations": {
        "VIZ:product_display": {
            "vizType": "sap.ushell.StaticAppLauncher",
            "businessApp": "product_display",
            "vizConfig": {
                "sap.app": { "title": "Display Product Catalog", "subTitle": "Fiori Elements v4" },
                "sap.flp": { "target": { "type": "URL", "url": "#product-display" } }
            }
        },
        "VIZ:masterDetail-display": {
            "vizType": "sap.ushell.StaticAppLauncher",
            "businessApp": "masterDetail-display",
            "vizConfig": {
                "sap.app": { "title": "Manage Products", "subTitle": "UI Adaptation at Runtime for SAP Fiori Elements" },
                "sap.flp": { "target": { "type": "URL", "url": "#masterDetail-display" } }
            }
        }
    },
    "applications": {
        "manage.news": {
            "sap.app": {
                "id": "manage.news",
                "title": "Manage News",
                "crossNavigation": {
                    "inbounds": {
                        "NewsArticle-display": {
                            "semanticObject": "NewsArticle",
                            "action": "display",
                            "title": "Manage News"
                        }
                    }
                }
            }
        },
        "product_display": {
            "sap.app": {
                "id": "sap.ui.demoapps.rta.fev4",
                "title": "Display Product Catalog",
                "subTitle": "Fiori Elements v4",
                "crossNavigation": {
                    "inbounds": {
                        "product-display": {
                            "semanticObject": "product",
                            "action": "display",
                            "title": "Display Product Catalog"
                        }
                    }
                }
            },
            "sap.ui5": { "componentName": "sap.ui.demoapps.rta.fev4" },
            "sap.ui": { "technology": "UI5" },
            "sap.platform.runtime": {
                "componentProperties": { "url": "/test-resources/sap/ui/demoapps/demokit/rta/fev4" }
            }
        },
        "masterDetail-display": {
            "sap.app": {
                "id": "sap.ui.demoapps.rta.fe",
                "title": "Manage Products",
                "subTitle": "UI Adaptation at Runtime for SAP Fiori Elements",
                "crossNavigation": {
                    "inbounds": {
                        "masterDetail-display": {
                            "semanticObject": "masterDetail",
                            "action": "display",
                            "title": "Manage Products"
                        }
                    }
                }
            },
            "sap.ui5": { "componentName": "sap.ui.demoapps.rta.fe" },
            "sap.ui": { "technology": "UI5" },
            "sap.platform.runtime": {
                "componentProperties": { "url": "/test-resources/sap/ui/demoapps/demokit/rta/fe" }
            }
        }
    },
    "pages": {
        "SAP_BASIS_PG_UI_MYHOME": {
            "identification": {
                "id": "SAP_BASIS_PG_UI_MYHOME"
            },
            "payload": {
                "layout": {
                    "sectionOrder": [
                        "homeAppsSection"
                    ]
                },
                "sections": {
                    "homeAppsSection": {
                        "id": "homeAppsSection",
                        "title": "Recently Added Apps",
                        "default": true,
                        "layout": {
                            "vizOrder": []
                        },
                        "viz": {}
                    }
                }
            }
        }
    }
}
