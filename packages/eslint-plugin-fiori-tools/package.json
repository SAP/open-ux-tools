{
    "name": "@sap-ux/eslint-plugin-fiori-tools",
    "version": "10.7.13",
    "description": "Custom linting plugin for Fiori tools apps",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "https://github.com/SAP/open-ux-tools.git",
        "directory": "packages/eslint-plugin-fiori-tools"
    },
    "keywords": [
        "eslint",
        "eslintplugin",
        "eslint-plugin"
    ],
    "main": "./lib/index.js",
    "scripts": {
        "build": "node esbuild.mjs --production",
        "build:dev": "node esbuild.mjs",
        "check-types": "tsc --noEmit",
        "watch": "node esbuild.mjs --watch",
        "clean": "rimraf --glob lib coverage *.tsbuildinfo",
        "format": "prettier --write '**/*.{js,json,ts,yaml,yml}' --ignore-path ../../.prettierignore",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "test": "cross-env \"NODE_OPTIONS=--experimental-vm-modules\" jest --ci --forceExit --detectOpenHandles --colors --maxWorkers=50%",
        "tgz:package": "pnpm pack"
    },
    "dependencies": {
        "@typescript-eslint/eslint-plugin": "8.61.1",
        "@typescript-eslint/parser": "8.61.1"
    },
    "devDependencies": {
        "@babel/core": "8.0.0-rc.6",
        "@babel/eslint-parser": "8.0.0-rc.6",
        "@babel/parser": "8.0.0-rc.6",
        "@eslint/js": "10.0.1",
        "@eslint/json": "0.14.0",
        "@eslint/core": "1.1.1",
        "@eslint/config-helpers": "0.5.3",
        "@eslint/plugin-kit": "0.6.1",
        "@humanwhocodes/momoa": "^3.3.9",
        "@jest/globals": "30.4.1",
        "@sap-ux/fiori-annotation-api": "workspace:*",
        "@sap-ux/odata-annotation-core": "workspace:*",
        "@sap-ux/odata-vocabularies": "workspace:*",
        "@sap-ux/odata-entity-model": "workspace:*",
        "@sap-ux/project-access": "workspace:*",
        "@sap-ux/vocabularies-types": "0.15.0",
        "@typescript-eslint/rule-tester": "8.61.1",
        "@types/semver": "7.7.1",
        "@xml-tools/ast": "5.0.5",
        "@xml-tools/parser": "1.0.11",
        "cross-env": "10.1.0",
        "esbuild": "0.27.4",
        "eslint": "9.39.1",
        "eslint-plugin-eslint-plugin": "7.3.2",
        "globals": "17.6.0",
        "lodash": "4.18.1",
        "requireindex": "^1.2.0",
        "semver": "7.8.4",
        "synckit": "0.11.12",
        "yaml": "2.9.0"
    },
    "peerDependencies": {
        "eslint": "^9 || ^10",
        "typescript-eslint": "^8.57.2"
    },
    "engines": {
        "node": ">=22.x"
    },
    "license": "Apache-2.0",
    "files": [
        "LICENSE",
        "lib",
        "docs"
    ]
}
