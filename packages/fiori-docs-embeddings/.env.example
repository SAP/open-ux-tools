# SAP Fiori Tools MCP Server Configuration

# Basic Configuration
SERVER_PORT=3000
LOG_LEVEL=info

# GitHub Configuration (optional - pre-bundled docs used by default)
GITHUB_TOKEN=your_github_personal_access_token_here

# Cache Configuration
CACHE_DURATION=3600000

# Vector Database Configuration
VECTORDB_ENABLED=true
VECTORDB_PATH=./data/vectors
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
BATCH_SIZE=10

# Code Generation Features (NEW!)
# Enable advanced code search and generation capabilities
CODE_GENERATION_ENABLED=false
DUAL_EMBEDDING_ENABLED=false

# Code Embedding Configuration
CODE_EMBEDDING_MODEL=microsoft/codebert-base
CODE_COMPLEXITY_ANALYSIS=true
LAZY_MODEL_LOADING=true

# Search Configuration
SEMANTIC_CODE_RATIO=0.7
CODE_EMBEDDING_BATCH_SIZE=5

# OpenAI Configuration (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Index Configuration
INDEX_TYPE=ivf_pq

# To enable the new code generation features:
# 1. Set CODE_GENERATION_ENABLED=true
# 2. Optionally set DUAL_EMBEDDING_ENABLED=true for better code pattern matching
# 3. The system will automatically download CodeBERT model on first use (~200MB)
# 4. New MCP tools will be available: smart_code_search, generate_code_suggestions, etc.