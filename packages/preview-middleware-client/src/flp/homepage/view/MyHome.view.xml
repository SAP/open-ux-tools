<mvc:View
    xmlns="sap.cux.home"
    xmlns:m="sap.m"
    xmlns:dt="sap.ui.dt"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:w="sap.ui.integration.widgets"
    xmlns:shell="sap.ushell.ui.shell"
    xmlns:controls="open.ux.preview.client.flp.homepage.controls"
    displayBlock="true"
    controllerName="open.ux.preview.client.flp.homepage.controller.MyHome"
    class="sapUShellFullHeight"
>
    <m:Page
        id="page"
        showHeader="true"
        class="homeLayout sapUiResponsiveContentPadding sapUiLayoutPadding sapCuxBaseLayout"
    >
        <m:customHeader>
            <m:OverflowToolbar id="salutationBar" class="salutationBar" height="5rem" dt:designtime="not-adaptable-tree">
                <m:VBox id="headerLeftContainer" gap="0.125rem" renderType="Bare" class="hideOverflow">
                    <m:Text id="headerDate"/>
                    <m:Title
                        id="greetingTitle"
                        titleStyle="{= ${view>/deviceType} === 'XLargeDesktop' ? 'H3' : 'H4'}"
                    />
                </m:VBox>
                <m:ToolbarSpacer id="headerToolbarSpacer"/>
                <m:HBox
                    id="headerRightContainer"
                    gap="0.5rem"
                    alignItems="End"
                    renderType="Bare"
                    class="hideOverflow"
                >
                    <m:Button
                        id="terminalWarningsBtn"
                        type="Ghost"
                        icon="sap-icon://alert"
                        text="{i18n>terminalWarnings}"
                        tooltip="{i18n>terminalWarnings}"
                        press=".onTerminalWarningsButtonPress"
                        visible="{view>/hasWarnings}"
                    />
                </m:HBox>
            </m:OverflowToolbar>
        </m:customHeader>

        <AppsContainer id="appsContainer" appsLoaded=".onAppsLoaded">
            <FavAppPanel id="favoriteApps" />
            <controls:SampleAppsPanel id="sampleApps" />
        </AppsContainer>

        <m:VBox
            id="insightsTilesContainer"
            renderType="Bare"
            class="sapCuxBaseContainer"
        >
            <m:HBox id="insightsTitleBar" alignItems="Center" renderType="Bare">
                <m:Title id="insightsTitle" level="H4" titleStyle="H4"/>
                <m:Button
                    id="insightsActionsBtn"
                    icon="sap-icon://slim-arrow-down"
                    type="Transparent"
                    tooltip="{i18n>more}"
                    press=".onInsightsActionsButtonPress"
                    class="sapUiTinyMarginBegin"
                />
            </m:HBox>
            <m:VBox
                id="noDataContainer"
                backgroundDesign="Solid"
                visible="{= ${view>/cards/length} === 0 }"
                class="sapCuxAppsPanel sapUiSmallMarginTop"
            >
                <m:IllustratedMessage
                    id="noDataIllustratedMessage"
                    illustrationSize="Dot"
                    illustrationType="sapIllus-NoData"
                    title="{i18n>noInsightsTitle}"
                    description="{i18n>noInsightsDesc}"
                    class="sapUiSmallMargin"
                >
                    <m:additionalContent>
                        <m:Button
                            id="refreshInsightsBtn"
                            type="Transparent"
                            icon="sap-icon://refresh"
                            text="{view>/insightsRefreshInfo}"
                            tooltip="{view>/insightsFullRefreshInfo}"
                            press=".onRefreshInsightsPress"
                        />
                    </m:additionalContent>
                </m:IllustratedMessage>
            </m:VBox>
            <f:GridContainer
                id="insightsCardContainer"
                visible="{= ${view>/cards/length} &gt; 0}"
                class="sapUiSmallMarginTop"
                items="{view>/cards}"
            >
                <w:Card id="card" manifest="{view>}" height="{view>/insightsCardHeight}"/>
                <f:layout>
                    <f:GridContainerSettings columnSize="{view>/insightsCardWidth}" rowSize="{view>/insightsCardHeight}" gap="1rem"/>
                </f:layout>
            </f:GridContainer>
        </m:VBox>
    </m:Page>
</mvc:View>
