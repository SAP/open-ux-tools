<mvc:View
    xmlns="sap.cux.home"
    xmlns:m="sap.m"
    xmlns:dt="sap.ui.dt"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:w="sap.ui.integration.widgets"
    displayBlock="true"
    controllerName="open.ux.preview.client.flp.homepage.controller.MyHome"
    class="sapUShellFullHeight"
>
    <m:Page
        id="page"
        class="homeLayout sapUiResponsiveContentPadding sapUiLayoutPadding sapCuxBaseLayout"
    >
        <m:customHeader>
            <m:OverflowToolbar id="salutationBar" class="salutationBar" height="5rem" dt:designtime="not-adaptable-tree">
                <m:VBox id="headerLeftContainer" gap="0.125rem" renderType="Bare" class="hideOverflow">
                    <m:Text id="headerDate"/>
                    <m:Title
                        id="greetingTitle"
                        level="H2"
                        titleStyle="{= ${view>/deviceType} === 'XLargeDesktop' ? 'H3' : 'H4'}"
                    />
                </m:VBox>
                <m:ToolbarSpacer id="headerToolbarSpacer"/>
                <m:GenericTag
                    id="devPreviewTag"
                    text="{i18n>devPreviewBadge}"
                    status="Information"
                    design="StatusIconHidden"
                    tooltip="{i18n>devPreviewTooltip}"
                />
            </m:OverflowToolbar>
        </m:customHeader>

        <AppsContainer id="appsContainer">
            <FavAppPanel id="favoriteApps" />
        </AppsContainer>

        <m:VBox id="insightsTilesContainer" visible="{= ${view>/cards/length} > 0}" renderType="Bare" class="sapCuxBaseContainer">
            <m:Title id="insightsTitle" level="H4" titleStyle="H4"/>
            <f:GridContainer id="insightsCardContainer" class="sapUiSmallMarginTop" items="{view>/cards}">
                <w:Card id="card" manifest="{view>}" height="33rem"/>
                <f:layout>
                    <f:GridContainerSettings columnSize="{view>/insightsCardWidth}" gap="1rem"/>
                </f:layout>
            </f:GridContainer>
        </m:VBox>
    </m:Page>
</mvc:View>
